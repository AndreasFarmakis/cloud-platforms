# ---------- General ----------
TZ=Europe/Athens
IMAGE_TAG=v1
IMAGE_PREFIX=ghcr.io/<YOUR_GITHUB_USERNAME>

# ---------- RabbitMQ ----------
RABBITMQ_USER=demo
RABBITMQ_PASS=demo

# ---------- MinIO ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=demo-demo-demo

# ---------- ThingsBoard (RabbitMQ queue) ----------
TB_QUEUE_TYPE=rabbitmq
TB_RMQ_USER=demo
TB_RMQ_PASS=demo

# ---------- MariaDB (WordPress DB) ----------
WP_DB_ROOT_PASSWORD=demo
WP_DB_NAME=wordpress
WP_DB_USER=wp
WP_DB_PASSWORD=demo

# ---------- WordPress ----------
WP_PORT=8082

# ---------- Keycloak + Postgres ----------
KC_ADMIN=admin
KC_ADMIN_PASSWORD=demo
KC_PORT=8081

KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=demo
